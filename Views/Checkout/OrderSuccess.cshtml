
@model MyWeb.Models.Order

@{
    ViewData["Title"] = "Đặt hàng thành công";

    // Tính ngày dự kiến (Ví dụ: 3 đến 5 ngày sau)
    var estimateStart = Model.OrderDate.AddDays(3);
    var estimateEnd = Model.OrderDate.AddDays(5);
}

<div class="w-full flex flex-col items-center pt-10 pb-20 px-6">
    <div class="w-full max-w-5xl">

        <div class="flex flex-col items-center text-center mb-12">
            <div class="relative mb-6 group">
                <div class="absolute inset-0 bg-primary blur-2xl opacity-40 rounded-full scale-150 animate-pulse"></div>
                <div class="relative flex items-center justify-center size-24 rounded-full bg-primary shadow-xl shadow-primary/30">
                    <span class="material-symbols-outlined text-[48px] text-[#181811] font-bold">check</span>
                </div>
            </div>
            <h1 class="text-[#181811] text-3xl md:text-5xl font-black leading-tight tracking-[-0.02em] mb-4">
                Đặt hàng thành công!
            </h1>
            <p class="text-[#5c5b4f] text-lg font-medium mb-2">Cảm ơn bạn đã tin tưởng và mua sắm tại TechZone.</p>

            <div class="inline-flex items-center gap-2 px-4 py-2 bg-white rounded-full border border-gray-200 shadow-sm mt-2">
                <span class="text-sm text-gray-500">Mã đơn hàng:</span>
                <span class="text-base font-bold text-[#181811]">#@Model.Id</span>
                <button class="text-gray-400 hover:text-primary transition-colors ml-2" title="Sao chép" onclick="navigator.clipboard.writeText('#@Model.Id'); alert('Đã sao chép mã đơn hàng!')">
                    <span class="material-symbols-outlined text-[16px]">content_copy</span>
                </button>
            </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
            <div class="lg:col-span-8 flex flex-col gap-6">

                <section class="bg-white rounded-[2rem] p-6 md:p-8 shadow-sm border border-gray-100">
                    <div class="flex items-center justify-between mb-6">
                        <h2 class="text-xl font-bold text-[#181811] flex items-center gap-2">
                            <span class="material-symbols-outlined text-primary">shopping_bag</span>
                            Sản phẩm đã đặt
                        </h2>
                        <span class="text-sm text-gray-500 font-medium">@Model.OrderDetails?.Count() sản phẩm</span>
                    </div>

                    <div class="flex flex-col gap-6">
                        @if (Model.OrderDetails != null)
                        {
                            @foreach (var item in Model.OrderDetails)
                            {
                                <div class="flex flex-col sm:flex-row gap-4 sm:items-center">
                                    <div class="relative size-24 sm:size-32 rounded-2xl bg-neutral-light overflow-hidden flex-shrink-0 border border-gray-100">
                                        <div class="w-full h-full bg-center bg-cover" style="background-image: url('@(item.Product?.ImageUrl ?? "https://placehold.co/150")');"></div>
                                        <span class="absolute bottom-1 right-1 bg-black/60 text-white text-[10px] px-1.5 py-0.5 rounded backdrop-blur-sm">@item.Quantity</span>
                                    </div>

                                    <div class="flex-1 min-w-0">
                                        <div class="flex flex-col sm:flex-row sm:justify-between sm:items-start gap-1 mb-2">
                                            <h3 class="font-bold text-lg text-[#181811] truncate pr-4">@item.Product?.Name</h3>
                                            <span class="font-bold text-lg whitespace-nowrap">@((item.Price * item.Quantity).ToString("#,##0"))₫</span>
                                        </div>

                                        <div class="flex flex-wrap gap-2 mb-3">
                                            <span class="inline-flex items-center text-sm text-gray-500 bg-gray-50 px-3 py-1 rounded-full border border-gray-100">
                                                Đơn giá: @item.Price.ToString("#,##0")₫
                                            </span>
                                        </div>
                                    </div>
                                </div>
                                @if (item != Model.OrderDetails.Last())
                                {
                                    <div class="h-px bg-gray-100 w-full"></div>
                                }
                            }
                        }
                    </div>
                </section>

                <section class="grid grid-cols-1 md:grid-cols-2 gap-6">

                    <div class="bg-white rounded-[2rem] p-6 md:p-8 shadow-sm border border-gray-100 flex flex-col h-full">
                        <h2 class="text-lg font-bold text-[#181811] mb-4 flex items-center gap-2">
                            <span class="material-symbols-outlined text-gray-400">local_shipping</span>
                            Giao hàng đến
                        </h2>
                        <div class="flex-1 flex flex-col gap-1 text-[#181811]">
                            <p class="font-bold text-lg">@Model.ReceiverName</p>
                            <p class="text-gray-600">@Model.ReceiverPhone</p>
                            <p class="text-gray-600 mt-2 leading-relaxed">@Model.ReceiverAddress</p>

                            @if (!string.IsNullOrEmpty(Model.Note))
                            {
                                <div class="mt-3 p-3 bg-gray-50 rounded-xl border border-dashed border-gray-200 text-sm">
                                    <span class="font-bold text-gray-500">Ghi chú:</span> <span class="text-gray-700">@Model.Note</span>
                                </div>
                            }
                        </div>
                    </div>

                    <div class="bg-white rounded-[2rem] p-6 md:p-8 shadow-sm border border-gray-100 flex flex-col h-full">
                        <h2 class="text-lg font-bold text-[#181811] mb-4 flex items-center gap-2">
                            <span class="material-symbols-outlined text-gray-400">calendar_clock</span>
                            Thông tin vận chuyển
                        </h2>
                        <div class="flex-1 flex flex-col justify-between gap-4">
                            <div>
                                <p class="text-sm text-gray-500 mb-1">Đơn vị vận chuyển</p>
                                <div class="flex items-center gap-2">
                                    <img src="https://cdn.haitrieu.com/wp-content/uploads/2022/05/Logo-GHN-Slogan-En.png" class="h-6 object-contain" alt="GHN" />
                                    <p class="font-bold text-[#181811]">Giao Hàng Nhanh (GHN)</p>
                                </div>
                            </div>

                            <div class="p-4 bg-yellow-50 rounded-xl border border-yellow-100">
                                <p class="text-sm text-yellow-800 font-bold mb-1">Dự kiến giao hàng</p>
                                <p class="text-lg font-black text-[#181811]">
                                    @estimateStart.ToString("dd/MM") - @estimateEnd.ToString("dd/MM")
                                </p>
                                <div class="w-full bg-yellow-200 h-1.5 rounded-full mt-3 overflow-hidden">
                                    <div class="bg-primary h-full w-1/4 rounded-full animate-pulse"></div>
                                </div>
                                <p class="text-[10px] text-yellow-700 mt-1 text-right">Đang xử lý đơn hàng</p>
                            </div>
                        </div>
                    </div>
                </section>
            </div>

            <div class="lg:col-span-4">
                <div class="sticky top-28 flex flex-col gap-6">
                    <div class="bg-white rounded-[2rem] p-6 md:p-8 shadow-sm border border-gray-100">
                        <h2 class="text-xl font-bold text-[#181811] mb-6">Chi tiết thanh toán</h2>

                        <div class="flex flex-col gap-3 mb-6">
                            <div class="flex justify-between text-sm">
                                <span class="text-gray-500">Tạm tính</span>
                                <span class="font-medium text-[#181811]">@Model.TotalAmount.ToString("#,##0")₫</span>
                            </div>
                            <div class="flex justify-between text-sm">
                                <span class="text-gray-500">Phí vận chuyển</span>
                                <span class="font-medium text-[#181811]">@Model.ShippingFee.ToString("#,##0")₫</span>
                            </div>
                            @if (Model.DiscountAmount != 0)
                            {
                                <div class="flex justify-between text-sm text-green-600">
                                    <span class="flex items-center gap-1"><span class="material-symbols-outlined text-[16px]">loyalty</span> Giảm giá</span>
                                    <span class="font-bold">-@Model.DiscountAmount.ToString("#,##0")₫</span>
                                </div>
                            }
                        </div>

                        <div class="border-t border-dashed border-gray-200 pt-4 mb-6">
                            <div class="flex justify-between items-end mb-1">
                                <span class="text-base font-bold text-[#181811]">Tổng cộng</span>
                                <span class="text-2xl font-black text-[#181811]">@Model.FinalAmount.ToString("#,##0")₫</span>
                            </div>
                            <p class="text-xs text-gray-400 text-right">(Đã bao gồm VAT)</p>
                        </div>

                        <div class="flex items-center gap-3 p-3 bg-neutral-light rounded-xl mb-2">
                            <div class="size-8 rounded-full bg-white flex items-center justify-center text-green-600 shadow-sm">
                                <span class="material-symbols-outlined text-[20px]">
                                    @(Model.PaymentMethod == "COD" ? "payments" : "account_balance")
                                </span>
                            </div>
                            <div class="flex-1">
                                <p class="text-xs text-gray-500 font-medium">Phương thức thanh toán</p>
                                <p class="text-sm font-bold text-[#181811]">
                                    @(Model.PaymentMethod == "COD" ? "Thanh toán khi nhận hàng (COD)" : "Chuyển khoản ngân hàng")
                                </p>
                            </div>
                        </div>

                        <div class="mt-2 text-center">
                            @if (Model.PaymentMethod == "COD")
                            {
                                <span class="inline-flex items-center gap-1 px-3 py-1 rounded-full bg-gray-100 text-gray-600 text-xs font-bold">
                                    <span class="size-2 rounded-full bg-gray-400"></span> Chưa thanh toán
                                </span>
                            }
                            else
                            {
                                <span class="inline-flex items-center gap-1 px-3 py-1 rounded-full bg-yellow-100 text-yellow-700 text-xs font-bold">
                                    <span class="size-2 rounded-full bg-yellow-500 animate-pulse"></span> Chờ xác nhận chuyển khoản
                                </span>
                            }
                        </div>

                    </div>

                    <div class="flex flex-col gap-3">
                        <a href="/Product" class="no-underline w-full flex items-center justify-center gap-2 rounded-full h-14 bg-primary text-[#181811] text-base font-bold hover:brightness-95 transition-all shadow-lg shadow-primary/20 transform hover:-translate-y-0.5">
                            Tiếp tục mua sắm
                            <span class="material-symbols-outlined">arrow_forward</span>
                        </a>
                        <a href="/Order/History" class="w-full flex items-center justify-center gap-2 rounded-full h-14 bg-white border border-gray-200 text-[#181811] text-base font-bold hover:bg-gray-50 transition-all no-underline">
                            <span class="material-symbols-outlined">history</span>
                            Xem lịch sử đơn hàng
                        </a>
                    </div>

                    <div class="text-center">
                        <p class="text-sm text-gray-500">
                            Có vấn đề với đơn hàng? <a class="font-bold text-[#181811] underline decoration-primary decoration-2 underline-offset-2 hover:text-primary-dark" href="/Home/Contact">Liên hệ hỗ trợ</a> ngay.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>