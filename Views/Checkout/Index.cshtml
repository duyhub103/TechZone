@model CheckoutViewModel



@{
    ViewData["Title"] = "Thanh toán";
}


<form asp-action="PlaceOrder" method="post">

    <main class="flex-1 w-full max-w-[1440px] mx-auto px-6 md:px-10 py-8">
        <div class="hidden md:flex justify-center mb-8">
            <div class="flex items-center gap-4 text-sm font-medium text-gray-400">
                <div class="flex items-center gap-2 text-[#181811]">
                    <div class="flex items-center justify-center size-6 rounded-full border border-gray-300 text-xs font-bold text-gray-500">1</div>
                    <span>Giỏ hàng</span>
                </div>
                <div class="h-[1px] w-8 bg-gray-300"></div>
                <div class="flex items-center gap-2 text-[#181811]">
                    <div class="flex items-center justify-center size-6 rounded-full bg-primary text-[#181811] text-xs font-bold">2</div>
                    <span class="font-bold">Thanh toán</span>
                </div>
                <div class="h-[1px] w-8 bg-gray-300"></div>
                <div class="flex items-center gap-2">
                    <div class="flex items-center justify-center size-6 rounded-full border border-gray-300 text-xs font-bold">3</div>
                    <span>Hoàn tất</span>
                </div>
            </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-12">

            <div class="lg:col-span-7 xl:col-span-8 flex flex-col gap-6">

                <section class="bg-white rounded-[2rem] p-6 md:p-8 shadow-sm border border-gray-100">
                    <div class="flex items-center gap-3 mb-6 pb-4 border-b border-gray-100">
                        <span class="material-symbols-outlined text-primary text-[28px]">local_shipping</span>
                        <h2 class="text-xl font-bold">Thông tin giao hàng</h2>
                    </div>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div class="md:col-span-2">
                            <label class="block text-sm font-bold mb-2 text-gray-700">Họ và tên</label>
                            <input asp-for="ReceiverName"
                                   class="w-full rounded-xl border-gray-200 bg-neutral-light px-4 py-3 focus:border-primary focus:ring-primary transition-colors"
                                   placeholder="Nguyễn Văn A" />
                        </div>
                        <div>
                            <label class="block text-sm font-bold mb-2 text-gray-700">Số điện thoại</label>
                            <input asp-for="ReceiverPhone"
                                   class="w-full rounded-xl border-gray-200 bg-neutral-light px-4 py-3 focus:border-primary focus:ring-primary transition-colors"
                                   placeholder="0912 xxx xxx" />
                        </div>
                        <div>
                            <label class="block text-sm font-bold mb-2 text-gray-700">Email</label>
                            <input asp-for="ReceiverEmail"
                                   class="w-full rounded-xl border-gray-200 bg-neutral-light px-4 py-3 focus:border-primary focus:ring-primary transition-colors"
                                   placeholder="email@example.com" />
                        </div>
                        <div class="md:col-span-2">
                            <label class="block text-sm font-bold mb-2 text-gray-700">Địa chỉ nhận hàng</label>
                            <input asp-for="ReceiverAddress"
                                   class="w-full rounded-xl border-gray-200 bg-neutral-light px-4 py-3 focus:border-primary focus:ring-primary transition-colors"
                                   placeholder="Số nhà, tên đường" />
                        </div>
                        <div>
                            <label class="block text-sm font-bold mb-2 text-gray-700">Tỉnh / Thành phố</label>
                            <select class="w-full rounded-xl border-gray-200 bg-neutral-light px-4 py-3 focus:border-primary focus:ring-primary transition-colors">
                                <option>Hồ Chí Minh</option>
                                <option>Hà Nội</option>
                                <option>Đà Nẵng</option>
                            </select>
                        </div>
                        <div>
                            <label class="block text-sm font-bold mb-2 text-gray-700">Xã / Phường</label>
                            <select class="w-full rounded-xl border-gray-200 bg-neutral-light px-4 py-3 focus:border-primary focus:ring-primary transition-colors">
                                <option>Quận 1</option>
                                <option>Quận 3</option>
                                <option>Thành phố Thủ Đức</option>
                            </select>
                        </div>
                        <div class="md:col-span-2">
                            <label class="block text-sm font-bold mb-2 text-gray-700">Ghi chú (Tùy chọn)</label>
                            <textarea asp-for="Note"
                                      class="w-full rounded-xl border-gray-200 bg-neutral-light px-4 py-3 focus:border-primary focus:ring-primary transition-colors"
                                      placeholder="Ví dụ: Giao hàng giờ hành chính"
                                      rows="2"></textarea>
                        </div>
                    </div>
                </section>

                <section class="bg-white rounded-[2rem] p-6 md:p-8 shadow-sm border border-gray-100">
                    <div class="flex items-center gap-3 mb-6 pb-4 border-b border-gray-100">
                        <span class="material-symbols-outlined text-primary text-[28px]">payments</span>
                        <h2 class="text-xl font-bold">Phương thức thanh toán</h2>
                    </div>
                    <div class="flex flex-col gap-4">
                        <label class="relative flex items-center p-4 rounded-xl border border-gray-200 cursor-pointer hover:border-primary/50 hover:bg-neutral-light/50 transition-all group">
                            <input checked class="size-5 text-black border-gray-300 focus:ring-primary" 
                                    asp-for="PaymentMethod"
                                    type="radio"
                                    value="COD" />
                            <div class="ml-4 flex flex-1 items-center justify-between">
                                <div class="flex items-center gap-3">
                                    <div class="flex items-center justify-center size-10 bg-gray-100 rounded-lg text-gray-600 group-hover:bg-primary group-hover:text-black transition-colors">
                                        <span class="material-symbols-outlined">attach_money</span>
                                    </div>
                                    <div>
                                        <span class="block font-bold text-[#181811]">Thanh toán khi nhận hàng (COD)</span>
                                        <span class="block text-sm text-gray-500">Thanh toán tiền mặt khi shipper giao hàng</span>
                                    </div>
                                </div>
                            </div>
                        </label>
                        <label class="relative flex items-center p-4 rounded-xl border border-gray-200 cursor-pointer hover:border-primary/50 hover:bg-neutral-light/50 transition-all group">
                            <input class="size-5 text-black border-gray-300 focus:ring-primary" 
                                   asp-for="PaymentMethod"
                                   type="radio"
                                   value="CARD" />
                            <div class="ml-4 flex flex-1 items-center justify-between">
                                <div class="flex items-center gap-3">
                                    <div class="flex items-center justify-center size-10 bg-gray-100 rounded-lg text-gray-600 group-hover:bg-primary group-hover:text-black transition-colors">
                                        <span class="material-symbols-outlined">credit_card</span>
                                    </div>
                                    <div>
                                        <span class="block font-bold text-[#181811]">Thẻ Tín dụng / Ghi nợ</span>
                                        <span class="block text-sm text-gray-500">Visa, Mastercard, JCB</span>
                                    </div>
                                </div>
                                <div class="flex gap-2">
                                    <div class="h-6 w-10 bg-gray-200 rounded"></div>
                                    <div class="h-6 w-10 bg-gray-200 rounded"></div>
                                </div>
                            </div>
                        </label>
                        <label class="relative flex items-center p-4 rounded-xl border border-gray-200 cursor-pointer hover:border-primary/50 hover:bg-neutral-light/50 transition-all group">
                            <input class="size-5 text-black border-gray-300 focus:ring-primary" 
                                   asp-for="PaymentMethod"
                                   type="radio"
                                   value="EWALLET" />
                            <div class="ml-4 flex flex-1 items-center justify-between">
                                <div class="flex items-center gap-3">
                                    <div class="flex items-center justify-center size-10 bg-gray-100 rounded-lg text-gray-600 group-hover:bg-primary group-hover:text-black transition-colors">
                                        <span class="material-symbols-outlined">account_balance_wallet</span>
                                    </div>
                                    <div>
                                        <span class="block font-bold text-[#181811]">Ví điện tử</span>
                                        <span class="block text-sm text-gray-500">Momo, ZaloPay, VNPay</span>
                                    </div>
                                </div>
                            </div>
                        </label>
                    </div>
                </section>
            </div>

            <div class="lg:col-span-5 xl:col-span-4">
                <div class="bg-white rounded-[2rem] p-6 md:p-8 shadow-sm sticky top-28 border border-gray-100">
                    <h2 class="text-xl font-bold mb-6">
                        Đơn hàng (@Model.CartItems.Sum(x => x.Quantity) sản phẩm)
                    </h2>

                    <div class="flex flex-col gap-4 mb-6 max-h-[300px] overflow-y-auto pr-2 custom-scrollbar">

                            @foreach (var item in Model.CartItems)
                            {
                                // nếu là sp trên cùng thì k có border
                                <div class="flex gap-4 items-start @(item != Model.CartItems.First() ? "pt-4 border-t border-gray-100" : "")">
                                    <div class="w-20 h-20 flex-shrink-0 bg-neutral-light rounded-xl overflow-hidden border">
                                        <div class="w-full h-full bg-center bg-cover"
                                             style="background-image:url('@item.ProductImage')">
                                        </div>
                                    </div>

                                    <div class="flex-1">
                                        <h3 class="text-sm font-bold line-clamp-2">
                                            @item.ProductName
                                        </h3>
                                        <div class="flex items-center justify-between mt-1">
                                            <p class="text-sm text-gray-500">SL: @item.Quantity</p>
                                            <p class="text-sm font-bold">
                                                @((item.Price * item.Quantity).ToString("#,##0₫"))
                                            </p>
                                        </div>
                                    </div>
                                </div>
                            }
                    </div>

                    <div class="flex flex-col gap-3 py-6 border-t border-gray-100">
                        <div class="flex justify-between items-center text-sm text-gray-600">
                            <span>Tạm tính</span>
                            <span class="font-medium text-[#181811]">@Model.SubTotal.ToString("#,##0₫")</span>
                        </div>
                        <div class="flex justify-between items-center text-sm text-gray-600">
                            <span>Phí vận chuyển</span>
                            <span class="font-medium text-[#181811]">@Model.ShippingFeeText</span>
                        </div>
                        <div class="flex justify-between items-center text-sm text-green-600">
                            <span>Giảm giá</span>
                            <span class="font-medium">@Model.DiscountAmount.ToString("#,##0₫")</span>
                        </div>
                    </div>

                    <div class="flex justify-between items-center pt-6 border-t border-gray-200 mb-6">
                        <span class="text-base font-bold text-[#181811]">Tổng cộng</span>
                        <div class="text-right">
                            <span class="block text-2xl font-black text-[#181811] drop-shadow-sm" style="text-shadow: 1px 1px 0 #000;">@Model.GrandTotal.ToString("#,##0₫")</span>
                            @* <span class="text-xs text-gray-400 font-normal">(Đã bao gồm VAT)</span> *@
                        </div>
                    </div>

                    <button type="submit" class="w-full rounded-full bg-primary py-4 text-base font-bold text-[#181811] shadow-lg shadow-primary/20 hover:brightness-95 active:scale-[0.98] transition-all flex items-center justify-center gap-2 group no-underline">
                        <span>Đặt Hàng Ngay</span>
                        <span class="material-symbols-outlined transition-transform group-hover:translate-x-1">arrow_forward</span>
                    </button>

                    <p class="text-center text-xs text-gray-400 mt-4 flex items-center justify-center gap-1">
                        <span class="material-symbols-outlined text-[14px]">lock</span>
                        Thanh toán bảo mật SSL 100%
                    </p>                       
                </div>
            </div>
        </div>
    </main>
</form>