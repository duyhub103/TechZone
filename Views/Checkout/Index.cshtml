@model CheckoutViewModel

@{
    ViewData["Title"] = "Thanh toán";
}

<form asp-controller="Checkout" asp-action="PlaceOrder" method="post">
    <main class="flex-1 w-full max-w-[1440px] mx-auto px-6 md:px-10 py-8">
        
        <partial name="Partials/_CheckoutSteps" />

        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-12">
            
            <div class="lg:col-span-7 xl:col-span-8 flex flex-col gap-6">
                <partial name="Partials/_ShippingInfo" model="Model" />

                <partial name="Partials/_PaymentMethods" model="Model" />
            </div>

            <div class="lg:col-span-5 xl:col-span-4">
                <partial name="Partials/_OrderSummary" model="Model" />
            </div>

        </div>
    </main>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}