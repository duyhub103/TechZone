@model CheckoutViewModel

<div class="bg-white rounded-[2rem] p-6 md:p-8 shadow-sm sticky top-28 border border-gray-100">
    <h2 class="text-xl font-bold mb-6">
        Đơn hàng (@Model.CartItems.Sum(x => x.Quantity) sản phẩm)
    </h2>

    <div class="flex flex-col gap-4 mb-6 max-h-[300px] overflow-y-auto pr-2 custom-scrollbar">
        @foreach (var item in Model.CartItems)
        {
            <div class="flex gap-4 items-start @(item != Model.CartItems.First() ? "pt-4 border-t border-gray-100" : "")">
                <div class="w-20 h-20 flex-shrink-0 bg-neutral-light rounded-xl overflow-hidden border">
                    <div class="w-full h-full bg-center bg-cover" style="background-image:url('@item.ProductImage')"></div>
                </div>

                <div class="flex-1">
                    <h3 class="text-sm font-bold line-clamp-2">@item.ProductName</h3>
                    <div class="flex items-center justify-between mt-1">
                        <p class="text-sm text-gray-500">SL: @item.Quantity</p>
                        <p class="text-sm font-bold">@((item.Price * item.Quantity).ToString("#,##0₫"))</p>
                    </div>
                </div>
            </div>
        }
    </div>

    <div class="flex flex-col gap-3 py-6 border-t border-gray-100">
        <div class="flex justify-between items-center text-sm text-gray-600">
            <span>Tạm tính</span>
            <span class="font-medium text-[#181811]">@Model.SubTotal.ToString("#,##0₫")</span>
        </div>
        <div class="flex justify-between items-center text-sm text-gray-600">
            <span>Phí vận chuyển</span>
            <span class="font-medium text-[#181811]">@Model.ShippingFeeText</span>
        </div>
        <div class="flex justify-between items-center text-sm text-green-600">
            <span>Giảm giá</span>
            <span class="font-medium">@Model.DiscountAmount.ToString("#,##0₫")</span>
        </div>
    </div>

    <div class="flex justify-between items-center pt-6 border-t border-gray-200 mb-6">
        <span class="text-base font-bold text-[#181811]">Tổng cộng</span>
        <div class="text-right">
            <span class="block text-2xl font-black text-[#181811] drop-shadow-sm" style="text-shadow: 1px 1px 0 #000;">@Model.GrandTotal.ToString("#,##0₫")</span>
        </div>
    </div>

    <button type="submit" class="w-full rounded-full bg-primary py-4 text-base font-bold text-[#181811] shadow-lg shadow-primary/20 hover:brightness-95 active:scale-[0.98] transition-all flex items-center justify-center gap-2 group no-underline">
        <span>Đặt Hàng Ngay</span>
        <span class="material-symbols-outlined transition-transform group-hover:translate-x-1">arrow_forward</span>
    </button>

    <p class="text-center text-xs text-gray-400 mt-4 flex items-center justify-center gap-1">
        <span class="material-symbols-outlined text-[14px]">lock</span>
        Thanh toán bảo mật SSL 100%
    </p>
</div>