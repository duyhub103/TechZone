@model CheckoutViewModel

<section class="bg-white rounded-[2rem] p-6 md:p-8 shadow-sm border border-gray-100">
    <div class="flex items-center gap-3 mb-6 pb-4 border-b border-gray-100">
        <span class="material-symbols-outlined text-primary text-[28px]">payments</span>
        <h2 class="text-xl font-bold">Phương thức thanh toán</h2>
    </div>
    <div class="flex flex-col gap-4">
        <label class="relative flex items-center p-4 rounded-xl border border-gray-200 cursor-pointer hover:border-primary/50 hover:bg-neutral-light/50 transition-all group">
            <input checked class="size-5 text-black border-gray-300 focus:ring-primary" asp-for="PaymentMethod" type="radio" value="COD" />
            <div class="ml-4 flex flex-1 items-center justify-between">
                <div class="flex items-center gap-3">
                    <div class="flex items-center justify-center size-10 bg-gray-100 rounded-lg text-gray-600 group-hover:bg-primary group-hover:text-black transition-colors">
                        <span class="material-symbols-outlined">attach_money</span>
                    </div>
                    <div>
                        <span class="block font-bold text-[#181811]">Thanh toán khi nhận hàng (COD)</span>
                        <span class="block text-sm text-gray-500">Thanh toán tiền mặt khi shipper giao hàng</span>
                    </div>
                </div>
            </div>
        </label>

        <label class="relative flex items-center p-4 rounded-xl border border-gray-200 cursor-not-allowed opacity-60 bg-gray-50">
            <input class="size-5 text-black border-gray-300 focus:ring-primary" asp-for="PaymentMethod" type="radio" value="BANK_TRANSFER" disabled />
            <div class="ml-4 flex flex-1 items-center justify-between">
                <div class="flex items-center gap-3">
                    <div class="flex items-center justify-center size-10 bg-gray-100 rounded-lg text-gray-400">
                        <span class="material-symbols-outlined">account_balance</span>
                    </div>
                    <div>
                        <span class="block font-bold text-[#181811]">Chuyển khoản ngân hàng</span>
                        <span class="block text-sm text-gray-500">Chưa hỗ trợ – vui lòng chọn phương thức khác</span>
                    </div>
                </div>
                <div class="flex gap-2">
                    <div class="h-6 w-10 bg-gray-200 rounded"></div>
                    <div class="h-6 w-10 bg-gray-200 rounded"></div>
                </div>
            </div>
        </label>

        <label class="relative flex items-center p-4 rounded-xl border border-gray-200 cursor-pointer hover:border-primary/50 hover:bg-neutral-light/50 transition-all group">
            <input class="size-5 text-black border-gray-300 focus:ring-primary" asp-for="PaymentMethod" type="radio" value="EWALLET" />
            <div class="ml-4 flex flex-1 items-center justify-between">
                <div class="flex items-center gap-3">
                    <div class="flex items-center justify-center size-10 bg-gray-100 rounded-lg text-gray-600 group-hover:bg-primary group-hover:text-black transition-colors">
                        <span class="material-symbols-outlined">account_balance_wallet</span>
                    </div>
                    <div>
                        <span class="block font-bold text-[#181811]">Ví điện tử</span>
                        <span class="block text-sm text-gray-500">Momo, ZaloPay, VNPay</span>
                    </div>
                </div>
            </div>
        </label>
    </div>
</section>