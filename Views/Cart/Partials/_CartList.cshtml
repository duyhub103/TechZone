@model MyWeb.ViewModels.CartViewModel

<div class="flex-1 flex flex-col gap-6">
    <div class="hidden sm:flex px-6 pb-2 text-sm font-bold text-gray-400 uppercase tracking-wider">
        <div class="flex-1">Sản phẩm</div>
        <div class="w-32 text-center">Số lượng</div>
        <div class="w-32 text-right">Thành tiền</div>
        <div class="w-10"></div>
    </div>

        @foreach (var item in Model.Items)
        {
            <div class="bg-white p-4 sm:p-6 rounded-[2rem] flex flex-col sm:flex-row gap-6 items-center relative group hover:shadow-lg transition-shadow border border-transparent hover:border-gray-100">

                <button class="absolute top-4 right-4 sm:hidden text-gray-400 hover:text-red-500 transition-colors">
                    <span class="material-symbols-outlined">close</span>
                </button>

                <div class="w-full sm:w-32 aspect-square rounded-2xl bg-neutral-light overflow-hidden shrink-0 border border-gray-100">
                    <div class="w-full h-full bg-cover bg-center"
                         style="background-image: url('@item.ProductImage');">
                    </div>
                </div>

                <div class="flex-1 w-full flex flex-col sm:flex-row items-center justify-between gap-4">
                    <div class="flex flex-col gap-1 w-full sm:w-auto text-center sm:text-left">
                        <h3 class="text-lg font-bold text-[#181811]">@item.ProductName</h3>
                        <p class="text-sm text-gray-400 mt-1">
                            Đơn giá: @item.Price.ToString("#,##0₫")
                        </p>
                    </div>

                    <div class="flex items-center justify-between w-full sm:w-auto gap-8 lg:gap-12">
                        <div class="flex items-center bg-neutral-light rounded-full h-12 px-1 border border-gray-200">
                            <button class="size-10 flex items-center justify-center rounded-full hover:bg-white transition-all text-gray-600 hover:text-primary">
                                <span class="material-symbols-outlined text-[20px]">remove</span>
                            </button>

                            <input class="w-10 bg-transparent border-none text-center font-bold text-[#181811] focus:ring-0 p-0"
                                   readonly value="@item.Quantity" />

                            <button class="size-10 flex items-center justify-center rounded-full hover:bg-white transition-all text-gray-600 hover:text-primary">
                                <span class="material-symbols-outlined text-[20px]">add</span>
                            </button>
                        </div>

                        <div class="text-right w-32">
                            <p class="text-lg font-bold text-[#181811]">
                                @((item.Price * item.Quantity).ToString("#,##0₫"))
                            </p>
                        </div>

                        <button class="hidden sm:flex size-10 items-center justify-center rounded-full bg-gray-50 text-gray-400 hover:bg-red-50 hover:text-red-500 transition-colors w-10">
                            <span class="material-symbols-outlined text-[20px]">delete</span>
                        </button>
                    </div>
                </div>
            </div>
        }
</div>