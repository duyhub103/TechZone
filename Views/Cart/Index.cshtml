@{
    ViewData["Title"] = "Giỏ hàng";
}

<main class="flex-1 w-full bg-[#f8f8f5]">
    <section class="w-full max-w-[1440px] mx-auto px-6 md:px-10 py-8">
        <div class="flex items-center gap-2 text-sm text-gray-500 mb-6">
            <a class="hover:text-primary transition-colors font-medium" href="/">Trang chủ</a>
            <span class="material-symbols-outlined text-[16px]">chevron_right</span>
            <span class="text-[#181811] font-bold">Giỏ hàng</span>
        </div>

        <div class="flex items-end gap-4 mb-8">
            <h1 class="text-[#181811] text-3xl md:text-4xl font-black tracking-[-0.02em]">Giỏ hàng của bạn</h1>
            <span class="text-lg font-medium text-gray-500 mb-1">(3 sản phẩm)</span>
        </div>

        <div class="flex flex-col lg:flex-row gap-8">
            <div class="flex-1 flex flex-col gap-6">
                <div class="hidden sm:flex px-6 pb-2 text-sm font-bold text-gray-400 uppercase tracking-wider">
                    <div class="flex-1">Sản phẩm</div>
                    <div class="w-32 text-center">Số lượng</div>
                    <div class="w-32 text-right">Thành tiền</div>
                    <div class="w-10"></div>
                </div>

                <div class="bg-white p-4 sm:p-6 rounded-[2rem] flex flex-col sm:flex-row gap-6 items-center relative group hover:shadow-lg transition-shadow border border-transparent hover:border-gray-100">
                    <button class="absolute top-4 right-4 sm:hidden text-gray-400 hover:text-red-500"><span class="material-symbols-outlined">close</span></button>
                    <div class="w-full sm:w-32 aspect-square rounded-2xl bg-neutral-light overflow-hidden shrink-0 border border-gray-100">
                        <div class="w-full h-full bg-cover bg-center" style="background-image: url('https://placehold.co/150x150?text=Asus+G14');"></div>
                    </div>
                    <div class="flex-1 w-full flex flex-col sm:flex-row items-center justify-between gap-4">
                        <div class="flex flex-col gap-1 w-full sm:w-auto text-center sm:text-left">
                            <h3 class="text-lg font-bold text-[#181811]">Asus ROG Zephyrus G14</h3>
                            <div class="flex items-center justify-center sm:justify-start gap-2">
                                <span class="text-xs font-bold px-2 py-1 bg-gray-100 rounded text-gray-600">RTX 4060</span>
                                <span class="text-xs font-bold px-2 py-1 bg-gray-100 rounded text-gray-600">16GB RAM</span>
                            </div>
                            <p class="text-sm text-gray-400 mt-1">Đơn giá: 32.990.000₫</p>
                        </div>
                        <div class="flex items-center justify-between w-full sm:w-auto gap-8 lg:gap-12">
                            <div class="flex items-center bg-neutral-light rounded-full h-12 px-1 border border-gray-200">
                                <button class="size-10 flex items-center justify-center rounded-full hover:bg-white hover:shadow-sm transition-all text-gray-600 hover:text-primary"><span class="material-symbols-outlined text-[20px]">remove</span></button>
                                <input class="w-10 bg-transparent border-none text-center font-bold text-[#181811] focus:ring-0 p-0" readonly type="text" value="1" />
                                <button class="size-10 flex items-center justify-center rounded-full hover:bg-white hover:shadow-sm transition-all text-gray-600 hover:text-primary"><span class="material-symbols-outlined text-[20px]">add</span></button>
                            </div>
                            <div class="text-right w-32">
                                <p class="text-lg font-bold text-[#181811]">32.990.000₫</p>
                            </div>
                            <button class="hidden sm:flex size-10 items-center justify-center rounded-full bg-gray-50 text-gray-400 hover:bg-red-50 hover:text-red-500 transition-colors w-10">
                                <span class="material-symbols-outlined text-[20px]">delete</span>
                            </button>
                        </div>
                    </div>
                </div>

                <div class="bg-white p-4 sm:p-6 rounded-[2rem] flex flex-col sm:flex-row gap-6 items-center relative group hover:shadow-lg transition-shadow border border-transparent hover:border-gray-100">
                    <button class="absolute top-4 right-4 sm:hidden text-gray-400 hover:text-red-500"><span class="material-symbols-outlined">close</span></button>
                    <div class="w-full sm:w-32 aspect-square rounded-2xl bg-neutral-light overflow-hidden shrink-0 border border-gray-100">
                        <div class="w-full h-full bg-cover bg-center" style="background-image: url('https://placehold.co/150x150?text=Macbook+Pro');"></div>
                    </div>
                    <div class="flex-1 w-full flex flex-col sm:flex-row items-center justify-between gap-4">
                        <div class="flex flex-col gap-1 w-full sm:w-auto text-center sm:text-left">
                            <h3 class="text-lg font-bold text-[#181811]">MacBook Pro 14 M3</h3>
                            <div class="flex items-center justify-center sm:justify-start gap-2">
                                <span class="text-xs font-bold px-2 py-1 bg-gray-100 rounded text-gray-600">M3 Pro</span>
                                <span class="text-xs font-bold px-2 py-1 bg-gray-100 rounded text-gray-600">Space Black</span>
                            </div>
                            <p class="text-sm text-gray-400 mt-1">Đơn giá: 49.990.000₫</p>
                        </div>
                        <div class="flex items-center justify-between w-full sm:w-auto gap-8 lg:gap-12">
                            <div class="flex items-center bg-neutral-light rounded-full h-12 px-1 border border-gray-200">
                                <button class="size-10 flex items-center justify-center rounded-full hover:bg-white hover:shadow-sm transition-all text-gray-600 hover:text-primary"><span class="material-symbols-outlined text-[20px]">remove</span></button>
                                <input class="w-10 bg-transparent border-none text-center font-bold text-[#181811] focus:ring-0 p-0" readonly type="text" value="1" />
                                <button class="size-10 flex items-center justify-center rounded-full hover:bg-white hover:shadow-sm transition-all text-gray-600 hover:text-primary"><span class="material-symbols-outlined text-[20px]">add</span></button>
                            </div>
                            <div class="text-right w-32">
                                <p class="text-lg font-bold text-[#181811]">49.990.000₫</p>
                            </div>
                            <button class="hidden sm:flex size-10 items-center justify-center rounded-full bg-gray-50 text-gray-400 hover:bg-red-50 hover:text-red-500 transition-colors w-10">
                                <span class="material-symbols-outlined text-[20px]">delete</span>
                            </button>
                        </div>
                    </div>
                </div>

                <div class="bg-white p-4 sm:p-6 rounded-[2rem] flex flex-col sm:flex-row gap-6 items-center relative group hover:shadow-lg transition-shadow border border-transparent hover:border-gray-100">
                    <button class="absolute top-4 right-4 sm:hidden text-gray-400 hover:text-red-500"><span class="material-symbols-outlined">close</span></button>
                    <div class="w-full sm:w-32 aspect-square rounded-2xl bg-neutral-light overflow-hidden shrink-0 border border-gray-100">
                        <div class="w-full h-full bg-cover bg-center" style="background-image: url('https://placehold.co/150x150?text=ThinkPad');"></div>
                    </div>
                    <div class="flex-1 w-full flex flex-col sm:flex-row items-center justify-between gap-4">
                        <div class="flex flex-col gap-1 w-full sm:w-auto text-center sm:text-left">
                            <h3 class="text-lg font-bold text-[#181811]">Lenovo ThinkPad X1</h3>
                            <div class="flex items-center justify-center sm:justify-start gap-2">
                                <span class="text-xs font-bold px-2 py-1 bg-gray-100 rounded text-gray-600">Business</span>
                                <span class="text-xs font-bold px-2 py-1 bg-gray-100 rounded text-gray-600">Core i7</span>
                            </div>
                            <p class="text-sm text-gray-400 mt-1">Đơn giá: 38.990.000₫</p>
                        </div>
                        <div class="flex items-center justify-between w-full sm:w-auto gap-8 lg:gap-12">
                            <div class="flex items-center bg-neutral-light rounded-full h-12 px-1 border border-gray-200">
                                <button class="size-10 flex items-center justify-center rounded-full hover:bg-white hover:shadow-sm transition-all text-gray-600 hover:text-primary"><span class="material-symbols-outlined text-[20px]">remove</span></button>
                                <input class="w-10 bg-transparent border-none text-center font-bold text-[#181811] focus:ring-0 p-0" readonly type="text" value="1" />
                                <button class="size-10 flex items-center justify-center rounded-full hover:bg-white hover:shadow-sm transition-all text-gray-600 hover:text-primary"><span class="material-symbols-outlined text-[20px]">add</span></button>
                            </div>
                            <div class="text-right w-32">
                                <p class="text-lg font-bold text-[#181811]">38.990.000₫</p>
                            </div>
                            <button class="hidden sm:flex size-10 items-center justify-center rounded-full bg-gray-50 text-gray-400 hover:bg-red-50 hover:text-red-500 transition-colors w-10">
                                <span class="material-symbols-outlined text-[20px]">delete</span>
                            </button>
                        </div>
                    </div>
                </div>
            </div>

            <div class="lg:w-[400px] shrink-0">
                <div class="bg-white p-6 md:p-8 rounded-[2.5rem] sticky top-28 border border-gray-100 shadow-xl shadow-gray-200/50">
                    <h2 class="text-xl font-bold mb-6 flex items-center gap-2">
                        <span class="material-symbols-outlined text-primary">receipt_long</span>
                        Tổng đơn hàng
                    </h2>
                    <div class="flex flex-col gap-4 mb-6 pb-6 border-b border-gray-100 text-sm">
                        <div class="flex justify-between items-center text-gray-500">
                            <span>Tạm tính</span>
                            <span class="font-bold text-[#181811]">121.970.000₫</span>
                        </div>
                        <div class="flex justify-between items-center text-gray-500">
                            <span>Giảm giá</span>
                            <span class="font-bold text-green-600">-0₫</span>
                        </div>
                        <div class="flex justify-between items-center text-gray-500">
                            <span>Phí vận chuyển</span>
                            <span class="font-bold text-[#181811]">Miễn phí</span>
                        </div>
                    </div>

                    <div class="mb-6">
                        <label class="block text-xs font-bold text-gray-400 uppercase tracking-wider mb-2">Mã giảm giá</label>
                        <div class="flex gap-2">
                            <input class="flex-1 bg-neutral-light border-transparent focus:border-primary focus:ring-0 rounded-2xl text-sm h-12 px-4 placeholder:text-gray-400" placeholder="Nhập mã..." type="text" />
                            <button class="bg-[#181811] text-white px-5 rounded-2xl text-sm font-bold hover:bg-gray-800 transition-colors">Áp dụng</button>
                        </div>
                    </div>

                    <div class="flex justify-between items-end mb-8 bg-[#f8f8f5] p-4 rounded-2xl">
                        <span class="text-base font-bold text-gray-600">Tổng cộng</span>
                        <div class="text-right">
                            <span class="block text-2xl font-black text-[#181811] leading-none">121.970.000₫</span>
                            <span class="text-[10px] text-gray-400 font-bold uppercase">(Đã bao gồm VAT)</span>
                        </div>
                    </div>

                    <a href="/Checkout" class="group w-full bg-primary hover:brightness-105 text-[#181811] font-bold h-14 rounded-full text-lg shadow-lg shadow-primary/40 transition-all flex items-center justify-center gap-2 no-underline">
                        Tiến hành thanh toán
                        <span class="material-symbols-outlined group-hover:translate-x-1 transition-transform">arrow_forward</span>
                    </a>

                    <a class="flex items-center justify-center gap-2 mt-4 text-sm font-bold text-gray-400 hover:text-[#181811] transition-colors py-2 no-underline" href="/Product">
                        <span class="material-symbols-outlined text-[18px]">arrow_back</span>
                        Tiếp tục mua sắm
                    </a>

                    <div class="mt-8 pt-6 border-t border-gray-100 flex flex-col gap-3">
                        <p class="text-xs text-center text-gray-400 font-bold uppercase tracking-widest">Thanh toán an toàn</p>
                        <div class="flex justify-center gap-3 opacity-60 grayscale hover:grayscale-0 transition-all cursor-default">
                            <div class="h-8 w-12 bg-neutral-light rounded-lg flex items-center justify-center">
                                <span class="material-symbols-outlined text-gray-500">credit_card</span>
                            </div>
                            <div class="h-8 w-12 bg-neutral-light rounded-lg flex items-center justify-center">
                                <span class="material-symbols-outlined text-gray-500">account_balance</span>
                            </div>
                            <div class="h-8 w-12 bg-neutral-light rounded-lg flex items-center justify-center">
                                <span class="material-symbols-outlined text-gray-500">qr_code_2</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
</main>