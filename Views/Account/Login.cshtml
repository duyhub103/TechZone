@{
    ViewData["Title"] = "Đăng nhập";
}

<div class="flex flex-col items-center justify-center w-full px-4 md:px-10 py-10 bg-[#f2f2eb] min-h-[80vh]">
    <div class="flex w-full max-w-6xl bg-white rounded-[2.5rem] shadow-2xl overflow-hidden min-h-[700px]">

        <div class="hidden lg:flex w-1/2 bg-[#1a1a1a] relative flex-col justify-between p-12 md:p-16 text-white bg-cover bg-center group"
             style="background-image: url('https://placehold.co/800x1200?text=TechZone+Banner');">
            <div class="absolute inset-0 bg-[#181811]/70 backdrop-blur-[2px] transition-opacity duration-500"></div>
            <div class="relative z-10 h-full flex flex-col justify-between">
                <div>
                    <div class="flex items-center gap-3 mb-8">
                        <span class="material-symbols-outlined text-[40px] text-primary">laptop_mac</span>
                        <h2 class="text-3xl font-bold tracking-tight">TechZone</h2>
                    </div>
                    <h3 class="text-5xl font-black leading-[1.1] mb-6">
                        Thế giới công nghệ<br />
                        <span class="text-primary">trong tầm tay bạn.</span>
                    </h3>
                    <p class="text-gray-300 text-lg max-w-md font-medium">Đăng nhập để nhận ưu đãi thành viên độc quyền và theo dõi đơn hàng dễ dàng hơn.</p>
                </div>
                <div class="space-y-4">
                    <div class="flex items-center gap-4">
                        <div class="size-10 rounded-full bg-white/10 flex items-center justify-center text-primary backdrop-blur-sm">
                            <span class="material-symbols-outlined">percent</span>
                        </div>
                        <div>
                            <p class="font-bold">Giảm 5% cho thành viên mới</p>
                            <p class="text-sm text-gray-400">Áp dụng cho đơn hàng đầu tiên</p>
                        </div>
                    </div>
                    <div class="flex items-center gap-4">
                        <div class="size-10 rounded-full bg-white/10 flex items-center justify-center text-primary backdrop-blur-sm">
                            <span class="material-symbols-outlined">local_shipping</span>
                        </div>
                        <div>
                            <p class="font-bold">Miễn phí vận chuyển</p>
                            <p class="text-sm text-gray-400">Cho mọi đơn hàng trên 5 triệu</p>
                        </div>
                    </div>
                </div>
                <div class="text-sm text-gray-400 font-medium pt-8">
                    © 2025 TechZone Inc. All rights reserved.
                </div>
            </div>
        </div>

        <div class="w-full lg:w-1/2 p-8 md:p-12 lg:p-20 flex flex-col justify-center bg-white relative">
            <div class="lg:hidden flex items-center gap-2 mb-8 justify-center">
                <span class="material-symbols-outlined text-[32px] text-primary">laptop_mac</span>
                <h2 class="text-2xl font-bold text-[#181811]">TechZone</h2>
            </div>
            <div class="max-w-md mx-auto w-full">
                <div class="mb-8">
                    <h1 class="text-3xl md:text-4xl font-black text-[#181811] mb-3 tracking-tight">Xin chào! 👋</h1>
                    <p class="text-gray-500 text-lg">Vui lòng nhập thông tin để đăng nhập.</p>
                </div>

                <form class="flex flex-col gap-5">
                    <div class="group">
                        <label class="block text-sm font-bold text-[#181811] mb-2 ml-1" for="email">Email</label>
                        <div class="relative">
                            <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none text-gray-400 group-focus-within:text-primary transition-colors">
                                <span class="material-symbols-outlined text-[20px]">mail</span>
                            </div>
                            <input class="w-full h-12 rounded-xl border border-gray-200 bg-neutral-light pl-11 pr-4 focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all placeholder:text-gray-400 font-medium" id="email" placeholder="name@example.com" type="email" />
                        </div>
                    </div>
                    <div class="group">
                        <div class="flex justify-between items-center mb-2 ml-1">
                            <label class="block text-sm font-bold text-[#181811]" for="password">Mật khẩu</label>
                            <a class="text-sm font-bold text-gray-500 hover:text-primary transition-colors" href="#">Quên mật khẩu?</a>
                        </div>
                        <div class="relative">
                            <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none text-gray-400 group-focus-within:text-primary transition-colors">
                                <span class="material-symbols-outlined text-[20px]">lock</span>
                            </div>
                            <input class="w-full h-12 rounded-xl border border-gray-200 bg-neutral-light pl-11 pr-4 focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all placeholder:text-gray-400 font-medium" id="password" placeholder="••••••••" type="password" />
                        </div>
                    </div>
                    <div class="flex items-center gap-2 ml-1">
                        <input class="size-5 rounded-md border-gray-300 text-primary focus:ring-primary bg-neutral-light" id="remember" type="checkbox" />
                        <label class="text-sm font-medium text-gray-600 select-none cursor-pointer" for="remember">Ghi nhớ đăng nhập</label>
                    </div>
                    <button class="w-full h-14 rounded-xl bg-primary text-[#181811] font-bold text-lg hover:brightness-95 hover:shadow-lg hover:-translate-y-0.5 transition-all duration-200 mt-4 flex items-center justify-center gap-2 group" type="submit">
                        <span>Đăng nhập</span>
                        <span class="material-symbols-outlined text-[20px] transition-transform group-hover:translate-x-1">arrow_forward</span>
                    </button>
                </form>

                <div class="relative my-8 text-center">
                    <div class="absolute inset-0 flex items-center"><span class="w-full border-t border-gray-100"></span></div>
                    <span class="relative bg-white px-4 text-sm text-gray-400 font-medium">Hoặc đăng nhập với</span>
                </div>
                <div class="grid grid-cols-2 gap-4">
                    <button class="flex items-center justify-center gap-3 h-12 rounded-xl border border-gray-100 bg-white hover:bg-gray-50 hover:border-gray-300 transition-all font-bold text-sm text-[#181811]">
                        <img alt="Google" class="size-5" src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/google/google-original.svg" />
                        Google
                    </button>
                    <button class="flex items-center justify-center gap-3 h-12 rounded-xl border border-gray-100 bg-white hover:bg-gray-50 hover:border-gray-300 transition-all font-bold text-sm text-[#181811]">
                        <img alt="Facebook" class="size-5" src="https://upload.wikimedia.org/wikipedia/commons/b/b8/2021_Facebook_icon.svg" />
                        Facebook
                    </button>
                </div>
                <p class="mt-10 text-center text-gray-500 font-medium">
                    Bạn chưa có tài khoản?
                    <a class="font-bold text-[#181811] bg-primary/20 px-2 py-1 rounded-lg ml-1 hover:bg-primary transition-all" href="/Account/Register">Đăng ký ngay</a>
                </p>
            </div>
        </div>
    </div>
</div>