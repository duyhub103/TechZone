                <form asp-action="Register" method="post" class="flex flex-col gap-4">
                    @Html.AntiForgeryToken()

                    <div asp-validation-summary="ModelOnly" class="text-red-500 text-sm"></div>

                    <div class="group">
                        <label class="block text-sm font-bold mb-2 ml-1">Họ và tên</label>
                        <input asp-for="FullName"
                               class="w-full h-11 rounded-xl border border-gray-200 bg-neutral-light pl-11 pr-4 focus:border-primary focus:ring-1 focus:ring-primary outline-none font-medium"
                               placeholder="Nguyễn Văn A" />
                        <span asp-validation-for="FullName" class="text-red-500 text-sm"></span>
                    </div>

                    <div class="group">
                        <label class="block text-sm font-bold mb-2 ml-1">Email</label>
                        <input asp-for="Email"
                               class="w-full h-11 rounded-xl border border-gray-200 bg-neutral-light pl-11 pr-4 focus:border-primary focus:ring-1 focus:ring-primary outline-none font-medium"
                               placeholder="name@example.com" />
                        <span asp-validation-for="Email" class="text-red-500 text-sm"></span>
                    </div>

                    <div class="group">
                        <label class="block text-sm font-bold mb-2 ml-1">Mật khẩu</label>
                        <input asp-for="Password"
                               type="password"
                               class="w-full h-11 rounded-xl border border-gray-200 bg-neutral-light pl-11 pr-4 focus:border-primary focus:ring-1 focus:ring-primary outline-none placeholder:text-gray-400 font-medium" 
                               placeholder="••••••••" />
                        <span asp-validation-for="Password" class="text-red-500 text-sm"></span>
                    </div>

                    <div class="group">
                        <label class="block text-sm font-bold mb-2 ml-1">Xác nhận mật khẩu</label>
                        <input asp-for="ConfirmPassword"
                               type="password"
                               class="w-full h-11 rounded-xl border border-gray-200 bg-neutral-light pl-11 pr-4 focus:border-primary focus:ring-1 focus:ring-primary outline-none placeholder:text-gray-400 font-medium" 
                               placeholder="••••••••" />
                        <span asp-validation-for="ConfirmPassword" class="text-red-500 text-sm"></span>
                    </div>

                    <div class="flex items-start gap-3 ml-1">
                        <input asp-for="TermsAccepted" class="size-5 rounded-md border-gray-300 text-primary focus:ring-primary" />
                        <label asp-for="TermsAccepted" class="text-sm text-gray-600">
                            Tôi đồng ý điều khoản & chính sách
                        </label>
                    </div>
                    <span asp-validation-for="TermsAccepted" class="text-red-500 text-sm"></span>

                    <button type="submit"
                            class="w-full h-14 rounded-xl bg-primary text-[#181811] font-bold text-lg hover:brightness-95 transition-all">
                        Đăng ký ngay
                    </button>
                </form>

                <div class="relative my-6 text-center">
                    <div class="absolute inset-0 flex items-center"><span class="w-full border-t border-gray-100"></span></div>
                    <span class="relative bg-white px-4 text-sm text-gray-400 font-medium">Hoặc đăng nhập với</span>
                </div>
                <div class="grid grid-cols-2 gap-4">
                    <button class="flex items-center justify-center gap-3 h-12 rounded-xl border border-gray-100 bg-white hover:bg-gray-50 hover:border-gray-300 transition-all font-bold text-sm text-[#181811]">
                        <img alt="Google" class="size-5" src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/google/google-original.svg" />
                        Google
                    </button>
                    <button class="flex items-center justify-center gap-3 h-12 rounded-xl border border-gray-100 bg-white hover:bg-gray-50 hover:border-gray-300 transition-all font-bold text-sm text-[#181811]">
                        <img alt="Facebook" class="size-5" src="https://upload.wikimedia.org/wikipedia/commons/b/b8/2021_Facebook_icon.svg" />
                        Facebook
                    </button>
                </div>
                <p class="mt-8 text-center text-gray-500 font-medium">
                    Bạn đã có tài khoản?
                    <a class="font-bold text-[#181811] bg-primary/20 px-2 py-1 rounded-lg ml-1 hover:bg-primary transition-all" href="/Account/Login">Đăng nhập</a>
                </p>
            </div>
        </div>
    </div>
</div>