@using MyWeb.Models
@model Product

<div class="group flex flex-col gap-4 bg-white p-4 rounded-[2rem] hover:shadow-xl transition-shadow duration-300 relative">

    <div class="relative aspect-square w-full rounded-[1.5rem] bg-neutral-light overflow-hidden">

        @if (Model.IsFeatured)
        {
            <div class="absolute top-3 left-3 bg-primary text-[#181811] text-xs font-bold px-2 py-1 rounded-full z-10">Hot</div>
        }

        <div class="w-full h-full bg-center bg-cover transition-transform duration-500 group-hover:scale-110"
             style="background-image: url('@Model.ImageUrl');">
        </div>

        <div class="absolute bottom-3 right-3 flex gap-2 z-20 opacity-0 translate-y-4 group-hover:opacity-100 group-hover:translate-y-0 transition-all duration-300">

            <button class="size-10 bg-white rounded-full flex items-center justify-center shadow-md hover:bg-red-50 text-gray-400 hover:text-red-500 transition-colors"
                    title="Thêm vào yêu thích">
                <span class="material-symbols-outlined text-[20px]">favorite</span>
            </button>

            <button onclick="addToCart(@Model.Id, 1)"
                    class="size-10 bg-white rounded-full flex items-center justify-center shadow-md hover:bg-primary text-[#181811] transition-colors"
                    title="Thêm vào giỏ">
                <span class="material-symbols-outlined text-[20px]">add_shopping_cart</span>
            </button>

        </div>

    </div>

    <div class="flex flex-col gap-1 px-1">
        <div class="flex gap-1 mb-1 h-6 overflow-hidden">
            @if (Model.Attributes != null)
            {
                @foreach (var attr in Model.Attributes.Take(2))
                {
                    <span class="bg-gray-100 text-gray-600 text-[10px] font-bold px-2 py-0.5 rounded-full whitespace-nowrap">@attr.Value</span>
                }
            }
        </div>

        <h3 class="text-lg font-bold leading-snug group-hover:text-primary/90 transition-colors truncate">
            <a asp-controller="Product" asp-action="Detail" asp-route-id="@Model.Id">
                @Model.Name
            </a>
        </h3>

        <p class="text-gray-500 text-sm line-clamp-1">@(Model.ShortDescription ?? "Chưa có mô tả ngắn")</p>

        <div class="flex items-end gap-2 mt-2">
            <span class="text-xl font-bold">@Model.Price.ToString("#,##0")₫</span>
        </div>
    </div>
</div>