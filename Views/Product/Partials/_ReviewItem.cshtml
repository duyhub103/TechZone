@using MyWeb.Models
@model Review

<div class="bg-white p-6 rounded-[2rem] shadow-sm border border-gray-100 hover:border-primary/30 transition-colors review-item">
    <div class="flex justify-between items-start mb-4">
        <div class="flex items-center gap-4">
            <div class="size-12 rounded-full bg-[#181811] flex items-center justify-center font-bold text-primary text-lg uppercase">
                @(Model.User?.FullName?.FirstOrDefault().ToString() ?? "A")
            </div>
            <div>
                <h5 class="font-bold text-[#181811]">@(Model.User?.FullName ?? "Người dùng ẩn danh")</h5>

                <div class="flex text-yellow-400 text-[14px] mt-0.5">
                    @for (int i = 1; i <= 5; i++)
                    {
                        if (i <= Model.Rating)
                        {
                            <span class="material-symbols-outlined text-[16px] fill-current">star</span>
                        }
                        else
                        {
                            <span class="material-symbols-outlined text-[16px] text-gray-300">star</span>
                        }
                    }
                </div>
            </div>
        </div>
        <span class="text-xs text-gray-400 bg-gray-100 px-3 py-1 rounded-full">
            @Model.CreatedAt.ToString("dd/MM/yyyy")
        </span>
    </div>
    <p class="text-gray-600 leading-relaxed pl-16">
        @Model.Comment
    </p>
</div>