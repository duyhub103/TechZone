@using MyWeb.ViewModels
@model ProductDetailViewModel

@{
    // 1. Tính phần trăm dựa trên điểm trung bình
    // Ví dụ: 4.8 sao => 96%
    double percent = Model.AverageRating > 0 ? (Model.AverageRating / 5.0) * 100 : 0;
}

<div class="flex flex-col gap-6" id="danhgia">

    <div class="bg-[#181811] text-white p-8 md:p-10 rounded-[2.5rem] shadow-lg relative overflow-hidden">
        <div class="absolute top-0 right-0 w-64 h-64 bg-primary/20 rounded-full blur-[80px] -translate-y-1/2 translate-x-1/2"></div>
        <div class="relative z-10 flex flex-col md:flex-row items-center gap-10">
            <div class="flex flex-col items-center gap-2 min-w-[150px]">
                <span class="text-6xl font-black text-primary">@Model.AverageRating.ToString("0.0")</span>
                <div class="flex text-primary">
                    @for (int i = 1; i <= 5; i++)
                    {
                        if (Model.AverageRating >= i)
                        {
                            <span class="material-symbols-outlined fill-current">star</span>
                        }
                        else if (Model.AverageRating >= i - 0.5)
                        {
                            <span class="material-symbols-outlined fill-current">star_half</span>
                        }
                        else
                        {
                            <span class="material-symbols-outlined text-gray-600">star</span>
                        }
                    }
                </div>
                <span class="text-sm text-gray-400">@Model.TotalReviews đánh giá</span>
            </div>
            <div class="flex-1 w-full flex flex-col gap-3">
                <div class="flex items-center gap-4">
                    <span class="material-symbols-outlined text-[16px] text-primary fill-current">star</span>
                    <div class="flex-1 h-3 bg-white/10 rounded-full overflow-hidden backdrop-blur-sm">
                        <div class="h-full bg-primary rounded-full shadow-[0_0_10px_rgba(249,245,6,0.5)] transition-all duration-1000 ease-out"
                             style="width: @(percent.ToString("0"))%">
                        </div>
                    </div>
                    <span class="text-sm text-gray-400 w-10 text-right font-mono">@(percent.ToString("0"))%</span>
                </div>
                <p class="text-xs text-gray-500 text-center md:text-left pl-0 md:pl-20">
                    Dựa trên @Model.TotalReviews lượt đánh giá từ khách hàng đã mua sản phẩm.
                </p>
            </div>

            <div class="min-w-[180px]">
                @if (Model.CanReview)
                {
                    <button class="w-full py-4 bg-white text-[#181811] rounded-2xl font-bold hover:bg-primary transition-colors shadow-lg group"
                            onclick="toggleReviewForm()">
                        <span class="group-hover:hidden">Viết đánh giá</span>
                        <span class="hidden group-hover:inline">Chia sẻ ngay</span>
                    </button>
                }
                else
                {
                    <div class="text-center text-xs text-gray-400 bg-white/5 p-3 rounded-xl border border-white/10 backdrop-blur-md">
                        @if (!User.Identity?.IsAuthenticated ?? true)
                        {
                            <span>Vui lòng <a class="font-bold text-primary hover:underline" href="/Account/Login">đăng nhập</a> để đánh giá.</span>
                        }
                        else
                        {
                            <span class="flex items-center gap-1 justify-center">
                                <span class="material-symbols-outlined text-[14px]">info</span>
                                Mua hàng để đánh giá
                            </span>
                        }
                    </div>
                }
            </div>
        </div>

        <div id="reviewForm" class="hidden mt-8 pt-8 border-t border-gray-700/50 transition-all duration-300 ease-in-out">
            <form id="frmReview" onsubmit="submitReview(event)" class="max-w-2xl mx-auto">
                @Html.AntiForgeryToken()
                <input type="hidden" id="productId" value="@Model.MainProduct.Id" />
                <input type="hidden" id="ratingValue" value="5" />

                <div class="flex flex-col items-center gap-4 mb-6">
                    <p class="text-gray-300 font-medium">Bạn cảm thấy sản phẩm thế nào?</p>
                    <div class="flex gap-2" id="star-container">
                        @for (int i = 1; i <= 5; i++)
                        {
                            <button type="button"
                                    class="star-btn transition-transform hover:scale-110 focus:outline-none"
                                    data-value="@i"
                                    onclick="setRating(@i)"
                                    onmouseenter="hoverRating(@i)"
                                    onmouseleave="resetRating()">
                                <span class="material-symbols-outlined text-4xl text-gray-600 transition-colors duration-200" id="star-@i">star</span>
                            </button>
                        }
                    </div>
                    <span id="rating-text" class="text-primary font-bold text-lg">Tuyệt vời</span>
                </div>

                <div class="mb-6">
                    <textarea id="commentContent" rows="4"
                              class="w-full bg-[#2a2a24] text-white border border-gray-600 rounded-2xl p-4 focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all placeholder-gray-500"
                              placeholder="Chia sẻ cảm nhận của bạn về sản phẩm này... (Chất lượng, đóng gói, giao hàng)"></textarea>
                    <p id="error-msg" class="text-red-500 text-sm mt-2 hidden"></p>
                </div>

                <div class="flex justify-end gap-3">
                    <button type="button" onclick="toggleReviewForm()" class="px-6 py-3 rounded-xl text-gray-300 hover:bg-white/10 font-medium transition-colors">
                        Hủy bỏ
                    </button>
                    <button type="submit" id="btnSubmitReview" class="px-8 py-3 rounded-xl bg-primary text-[#181811] font-bold shadow-lg shadow-primary/20 hover:brightness-110 active:scale-95 transition-all flex items-center gap-2">
                        <span>Gửi đánh giá</span>
                        <span class="material-symbols-outlined text-[18px]">send</span>
                    </button>
                </div>
            </form>
        </div>
    </div>

    <div class="grid gap-4" id="review-container">
        @if (Model.Reviews != null && Model.Reviews.Any())
        {
            <partial name="Partials/_ReviewList" model="Model.Reviews" />
        }
        else
        {
            <div class="text-center py-10 bg-white rounded-[2rem] border border-gray-100">
                <span class="material-symbols-outlined text-4xl text-gray-300 mb-2">rate_review</span>
                <p class="text-gray-500">Chưa có đánh giá nào. Hãy là người đầu tiên!</p>
            </div>
        }
    </div>

    @if (Model.TotalReviews > 10)
    {
        <div class="flex justify-center mt-2">
            <button id="btnLoadMore" onclick="loadMoreReviews(@Model.MainProduct.Id)" class="mx-auto text-sm font-bold text-gray-500 hover:text-[#181811] py-2 px-6 border border-gray-200 rounded-full hover:bg-white hover:shadow-md transition-all">
                Xem thêm đánh giá
            </button>
        </div>
    }
</div>

<script>
    let currentReviewPage = 1;
    const pageSize = 10;
    let selectedRating = 5;
    const ratingTexts = ["", "Rất tệ", "Tệ", "Bình thường", "Tốt", "Tuyệt vời"];

    // Toggle Form Viết Đánh Giá
    function toggleReviewForm() {
        const form = document.getElementById('reviewForm');
        form.classList.toggle('hidden');
    }

    // Xử lý hiệu ứng Sao
    function updateStarUI(rating) {
        for (let i = 1; i <= 5; i++) {
            const star = document.getElementById(`star-${i}`);
            if (i <= rating) {
                star.classList.remove('text-gray-600');
                star.classList.add('text-primary', 'fill-current'); // text-primary là màu vàng
                star.innerText = 'star';
            } else {
                star.classList.remove('text-primary', 'fill-current');
                star.classList.add('text-gray-600');
                star.innerText = 'star';
            }
        }
        document.getElementById('rating-text').innerText = ratingTexts[rating];
    }

    function setRating(rating) {
        selectedRating = rating;
        document.getElementById('ratingValue').value = rating;
        updateStarUI(rating);
    }

    function hoverRating(rating) {
        updateStarUI(rating);
    }

    function resetRating() {
        updateStarUI(selectedRating);
    }

    // Khởi tạo trạng thái sao ban đầu
    document.addEventListener("DOMContentLoaded", () => {
        updateStarUI(5);
    });

    // --- LOGIC GỬI REVIEW (AJAX) ---

    async function submitReview(e) {
        e.preventDefault();

        const btnSubmit = document.getElementById('btnSubmitReview');
        const errorMsg = document.getElementById('error-msg');
        const productId = document.getElementById('productId').value;
        const comment = document.getElementById('commentContent').value;
        const token = document.querySelector('input[name="__RequestVerificationToken"]').value;

        // Reset error
        errorMsg.classList.add('hidden');
        errorMsg.innerText = '';

        if (!comment || comment.trim() === "") {
            errorMsg.innerText = "Vui lòng nhập nội dung đánh giá.";
            errorMsg.classList.remove('hidden');
            return;
        }

        // Loading state
        const originalText = btnSubmit.innerHTML;
        btnSubmit.innerHTML = '<span class="material-symbols-outlined animate-spin">progress_activity</span> Đang gửi...';
        btnSubmit.disabled = true;

        try {
            const response = await fetch('/Product/SubmitReview', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': token // Bắt buộc để qua ải ValidateAntiForgeryToken
                },
                body: JSON.stringify({
                    productId: parseInt(productId),
                    rating: selectedRating,
                    comment: comment
                })
            });

            if (response.ok) {
                const newReviewHtml = await response.text();

                // 1. Thêm review mới vào đầu danh sách
                const container = document.getElementById('review-container');
                const emptyMsg = document.getElementById('empty-review-msg');
                if (emptyMsg) emptyMsg.remove(); // Xóa thông báo "chưa có review" nếu có

                container.insertAdjacentHTML('afterbegin', newReviewHtml);

                // 2. Ẩn form và reset
                toggleReviewForm();
                document.getElementById('commentContent').value = '';
                alert("Cảm ơn bạn đã đánh giá sản phẩm!");

                // 3. Ẩn nút viết đánh giá (vì chỉ được review 1 lần)
                // Reload trang để cập nhật lại điểm trung bình (optional)
                window.location.reload();

            } else {
                const data = await response.json();
                errorMsg.innerText = data.message || "Có lỗi xảy ra, vui lòng thử lại.";
                errorMsg.classList.remove('hidden');
            }
        } catch (err) {
            console.error(err);
            errorMsg.innerText = "Lỗi kết nối server.";
            errorMsg.classList.remove('hidden');
        } finally {
            btnSubmit.innerHTML = originalText;
            btnSubmit.disabled = false;
        }
    }

    async function loadMoreReviews(productId) {
        const btn = document.getElementById('btnLoadMore');
        const originalText = btn.innerText;
        btn.innerText = "Đang tải...";
        btn.disabled = true;

        try {
            const response = await fetch(`/Product/GetMoreReviews?productId=${productId}&page=${currentReviewPage + 1}&pageSize=${pageSize}`);

            if (response.ok) {
                const html = await response.text();
                if (html.trim().length > 0) {
                    document.getElementById('review-container').insertAdjacentHTML('beforeend', html);
                    currentReviewPage++;
                    btn.innerText = originalText;
                    btn.disabled = false;
                } else {
                    btn.style.display = 'none';
                }
            } else {
                btn.innerText = "Lỗi tải trang";
            }
        } catch (error) {
            console.error(error);
            btn.innerText = "Thử lại";
            btn.disabled = false;
        }
    }
</script>