

@using MyWeb.ViewModels
@model ProductDetailViewModel


<div class="lg:col-span-5 flex flex-col gap-6">
    <div>
        <h1 class="text-3xl md:text-4xl font-black text-[#181811] leading-[1.15] mb-3 tracking-tight">
            @Model.MainProduct.Name
        </h1>
        <div class="flex flex-wrap items-center gap-4 text-sm mb-4">
            <div class="flex items-center gap-1 bg-neutral-light px-3 py-1 rounded-full">
                <div class="flex text-yellow-500">
                    @for (int i = 1; i <= 5; i++)
                    {
                        if (Model.AverageRating >= i)
                        {
                            <span class="material-symbols-outlined text-[16px] fill-current">star</span> // Sao đầy
                        }
                        else if (Model.AverageRating >= i - 0.5)
                        {
                            <span class="material-symbols-outlined text-[16px] fill-current">star_half</span> // Sao rưỡi
                        }
                        else
                        {
                            <span class="material-symbols-outlined text-[16px] text-gray-300">star</span> // Sao rỗng
                        }
                    }
                </div>
                <span class="font-bold text-[#181811] ml-1">
                    @(Model.AverageRating > 0 ? Model.AverageRating.ToString("0.0") : "0.0")
                </span>
                <span class="text-gray-400 mx-1">|</span>
                <span class="text-gray-500 underline decoration-dotted">
                    @Model.TotalReviews đánh giá
                </span>
            </div>
        </div>
        <p class="text-gray-600 leading-relaxed">
            @(Model.MainProduct.ShortDescription ?? "Đang cập nhật thông tin sản phẩm...")
        </p>
    </div>

    <div class="p-6 bg-[#f9f9f7] rounded-3xl border border-[#e5e5e0]">
        <div class="flex items-end gap-3 mb-1">
            <span class="text-4xl font-black text-[#181811]">
                @Model.MainProduct.Price.ToString("#,##0")₫
            </span>
        </div>

        @if (Model.MainProduct.Stock > 0)
        {
            <div class="flex items-center gap-2 text-xs font-bold text-green-600 uppercase tracking-wide">
                <span class="material-symbols-outlined text-[16px]">verified</span>
                Còn hàng - Giao ngay
            </div>
        }
        else
        {
                <div class="flex items-center gap-2 text-xs font-bold text-red-500 uppercase tracking-wide">
                    <span class="material-symbols-outlined text-[16px]">block</span>
                    Tạm hết hàng - Đăng ký Email bên dưới để nhận thông báo mới nhất
                </div>
        }   
    </div>
    <partial name="Partials/_ProductActions" model="Model.MainProduct" />
</div>