@using MyWeb.Models
@model IEnumerable<Product>


<section class="w-full max-w-[1440px] px-6 md:px-10 py-12 mb-8 border-t border-gray-200 mx-auto">
    <div class="flex items-center justify-between mb-8">
            <h2 class="text-[#181811] text-[28px] font-bold leading-tight tracking-[-0.015em]">Sản phẩm tương tự</h2>
            <a class="text-sm font-bold underline decoration-2 decoration-primary underline-offset-4 hover:text-gray-600 transition-colors" href="#">Xem tất cả</a>
        </div>

    @if (Model != null && Model.Any())
    {
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
            @foreach (var item in Model)
            {
                <partial name="_ProductCard" model="item" />
            }
        </div>
    }
    else
    {
        <div class="text-center text-gray-500 py-10">
            Chưa có sản phẩm tương tự.
        </div>
    }
</section>
