@using MyWeb.Models
@model Product


<div class="bg-white rounded-[2.5rem] p-8 md:p-10 shadow-sm">
    <div class="prose prose-lg max-w-none text-[#181811]" id="mota">

        @if (!string.IsNullOrEmpty(Model.Description))
        {
            @Html.Raw(Model.Description)
        }
        else
        {
            <div class="text-center py-10 text-gray-400">
                <span class="material-symbols-outlined text-4xl mb-2">description</span>
                <p>Nội dung chi tiết đang được cập nhật.</p>
            </div>
        }

    </div>
</div>



