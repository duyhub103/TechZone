@using MyWeb.ViewModels
@model ProductDetailViewModel

@{
    ViewData["Title"] = "Chi tiết sản phẩm";
}

<main class="flex-1 w-full bg-[#f8f8f5]">
    
    @{
        ViewData["BreadcrumbMiddle"] = "Sản phẩm";
        ViewData["BreadcrumbMiddleUrl"] = "/Product";
        ViewData["BreadcrumbCurrent"] = Model.MainProduct.Name;
    }

    <partial name="_Breadcrumb" />


    <section class="w-full max-w-[1440px] px-6 md:px-10 pb-12 mx-auto">
        <div class="bg-white rounded-[2.5rem] p-6 md:p-10 shadow-sm">
            <div class="grid grid-cols-1 lg:grid-cols-12 gap-10">

                <partial name="Partials/_ProductGallery" model="Model.MainProduct" />

                <partial name="Partials/_ProductInfo" model="Model" />

                
                             
            </div>
        </div>
    </section>

    <section class="w-full max-w-[1440px] px-6 md:px-10 pb-16 mx-auto">
        <div class="flex flex-col lg:flex-row gap-8">
            <div class="flex-1 flex flex-col gap-6">


                <partial name="Partials/_ProductTabsNav" />

                <partial name="Partials/_ProductDescription" model="Model.MainProduct" />

                <partial name="Partials/_ProductReviews" model="Model" />

            </div>

            <partial name="Partials/_TechSpecsSidebar" model="Model.MainProduct" />

        </div>
    </section>  
    
    
    
    <partial name="Partials/_RelatedProducts" model="Model.RelatedProducts" />

    <partial name="_NewsletterSection" />

</main>