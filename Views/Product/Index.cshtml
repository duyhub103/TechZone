@using MyWeb.Models
@using System.Linq
@model PaginatedList<MyWeb.Models.Product>


@{
    ViewData["Title"] = "Laptop Gaming";
}

<section class="w-full max-w-[1440px] px-6 md:px-10 pt-8 pb-4 mx-auto">
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-4">
        @{
            ViewData["BreadcrumbMiddle"] = "Sản phẩm";
            ViewData["BreadcrumbMiddleUrl"] = "/Product";
            ViewData["BreadcrumbCurrent"] = ""; // Index không có item cuối
        }

        <partial name="_Breadcrumb" />


        <div class="flex items-center gap-3">
            <span class="text-sm font-medium text-gray-600 hidden sm:block">Sắp xếp theo:</span>
            <div class="relative group">
                <button class="flex items-center gap-2 bg-white border border-gray-200 rounded-full px-4 py-2.5 text-sm font-medium hover:border-primary transition-colors">
                    <span>Phổ biến nhất</span>
                    <span class="material-symbols-outlined text-[20px]">expand_more</span>
                </button>
                <div class="absolute right-0 top-full mt-2 w-48 bg-white rounded-xl shadow-lg border border-gray-100 hidden group-hover:block z-20">
                    <a class="block px-4 py-2 hover:bg-neutral-light first:rounded-t-xl" href="#">Mới nhất</a>
                    <a class="block px-4 py-2 hover:bg-neutral-light" href="#">Giá: Thấp đến Cao</a>
                    <a class="block px-4 py-2 hover:bg-neutral-light last:rounded-b-xl" href="#">Giá: Cao đến Thấp</a>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="w-full max-w-[1440px] px-6 md:px-10 py-6 flex flex-col lg:flex-row gap-8 mx-auto">


    <partial name="Partials/_SidebarFilter"/>

    <div class="flex-1">

        <div class="flex flex-wrap gap-2 mb-6">
            <div class="inline-flex items-center gap-1 px-3 py-1 rounded-full bg-neutral-light text-xs font-bold text-gray-700">
                15 - 25 triệu
                <button class="hover:text-red-500"><span class="material-symbols-outlined text-[14px]">close</span></button>
            </div>
            <div class="inline-flex items-center gap-1 px-3 py-1 rounded-full bg-neutral-light text-xs font-bold text-gray-700">
                Dell
                <button class="hover:text-red-500"><span class="material-symbols-outlined text-[14px]">close</span></button>
            </div>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 gap-4">
            @if (Model != null && Model.Any())
            {
                foreach (var item in Model)
                {
                    <partial name="_ProductCard" model="item" />               
                }
            }
            else
            {
                <div class="col-span-full text-center py-10 text-gray-500">
                    Chưa có sản phẩm nào.
                </div>
            }
        </div>

        @if (Model.TotalPages > 1)
        {
            <div class="flex justify-center mt-12 gap-2">
                @{
                    var prevDisabled = !Model.HasPreviousPage ? "disabled opacity-50 cursor-not-allowed" : "";
                    var nextDisabled = !Model.HasNextPage ? "disabled opacity-50 cursor-not-allowed" : "";
                }

                @if (Model.HasPreviousPage)
                {
                    @* type và value giữ filter khi sang trang *@
                    <a asp-action="Index"
                       asp-route-page="@(Model.PageIndex - 1)"
                       asp-route-type="@ViewData["CurrentType"]"
                       asp-route-value="@ViewData["CurrentValue"]"
                       class="size-10 flex items-center justify-center rounded-full bg-white border border-gray-200 text-gray-500 hover:bg-gray-50 @prevDisabled">
                        <span class="material-symbols-outlined text-[20px]">chevron_left</span>
                    </a>
                }   

                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    if (i == Model.PageIndex)
                    {
                    // Trang hiện tại (Active)
                        <span class="size-10 flex items-center justify-center rounded-full bg-primary text-black font-bold shadow-md shadow-primary/30">@i</span>
                    }
                    else
                    {
                        // Các trang khác
                        <a asp-action="Index"
                           asp-route-page="@i"
                           asp-route-type="@ViewData["CurrentType"]"
                           asp-route-value="@ViewData["CurrentValue"]"
                           class="size-10 flex items-center justify-center rounded-full bg-white border border-gray-200 text-gray-600 font-medium hover:bg-gray-50 hover:border-gray-300 transition-all">@i</a>
                    }
                }
                @if (Model.HasNextPage)
                {
                    <a asp-action="Index"
                       asp-route-page="@(Model.PageIndex + 1)"
                       asp-route-type="@ViewData["CurrentType"]"
                       asp-route-value="@ViewData["CurrentValue"]"
                       class="size-10 flex items-center justify-center rounded-full bg-white border border-gray-200 text-gray-500 hover:bg-gray-50">
                        <span class="material-symbols-outlined text-[20px]">chevron_right</span>
                    </a>
                }
                
            </div>
        }


        @* <div class="flex justify-center mt-12 gap-2">
            <button class="size-10 flex items-center justify-center rounded-full bg-white border border-gray-200 text-gray-500 hover:bg-gray-50 disabled:opacity-50">
                <span class="material-symbols-outlined text-[20px]">chevron_left</span>
            </button>
            <button class="size-10 flex items-center justify-center rounded-full bg-primary text-black font-bold shadow-md shadow-primary/30">1</button>
            <button class="size-10 flex items-center justify-center rounded-full bg-white border border-gray-200 text-gray-600 font-medium hover:bg-gray-50 hover:border-gray-300 transition-all">2</button>
            <button class="size-10 flex items-center justify-center rounded-full bg-white border border-gray-200 text-gray-600 font-medium hover:bg-gray-50 hover:border-gray-300 transition-all">3</button>
            <span class="size-10 flex items-center justify-center text-gray-400">...</span>
            <button class="size-10 flex items-center justify-center rounded-full bg-white border border-gray-200 text-gray-500 hover:bg-gray-50 hover:border-gray-300 transition-all">
                <span class="material-symbols-outlined text-[20px]">chevron_right</span>
            </button>
        </div> *@

    </div>
</section>

<partial name="_NewsletterSection"/>