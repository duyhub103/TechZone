@{
    ViewData["Title"] = "Về chúng tôi";
}

<div class="w-full bg-white dark:bg-[#111a22]">
    <div class="relative flex min-h-[400px] flex-col gap-6 bg-cover bg-center items-center justify-center p-8"
         style="background-image: linear-gradient(rgba(0,0,0,0.7), rgba(0,0,0,0.7)), url('https://placehold.co/1920x600?text=Office+Space');">
        <div class="flex flex-col gap-4 text-center max-w-[800px]">
            <span class="text-primary font-bold tracking-wider uppercase text-sm">Chào mừng đến với TechZone</span>
            <h1 class="text-white text-4xl md:text-6xl font-black leading-tight drop-shadow-md">Kiến tạo phong cách số</h1>
        </div>
    </div>
</div>

<div class="px-4 md:px-20 lg:px-40 py-16 bg-white">
    <div class="max-w-[1200px] mx-auto grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div class="flex flex-col gap-6">
            <h2 class="text-3xl md:text-4xl font-bold">Hành trình từ đam mê đến thương hiệu hàng đầu</h2>
            <p class="text-gray-500 text-lg leading-relaxed">
                TechZone được thành lập vào năm 2015. Từ một cửa hàng nhỏ, chúng tôi đã vươn lên trở thành hệ thống phân phối laptop chính hãng uy tín.
            </p>
            <div class="flex gap-8 mt-4 pt-6 border-t border-gray-100">
                <div><h3 class="text-3xl font-bold text-primary">8+</h3><p class="text-sm text-gray-500">Năm kinh nghiệm</p></div>
                <div><h3 class="text-3xl font-bold text-primary">50k+</h3><p class="text-sm text-gray-500">Khách hàng</p></div>
            </div>
        </div>
        <div>
            <img src="https://placehold.co/600x400?text=Repair+Team" class="rounded-xl shadow-xl w-full">
        </div>
    </div>
</div>