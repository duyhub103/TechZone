@using MyWeb.Models
@model Banner

<section class="w-full max-w-[1440px] px-6 md:px-10 py-8 mb-12 mx-auto">
    <div class="relative w-full rounded-[2.5rem] overflow-hidden bg-[#1a1a1a] text-white">
        <div class="absolute inset-0 bg-cover bg-center opacity-40 mix-blend-overlay"
             style="background-image: url('@Model.ImageUrl');"></div>

        <div class="relative z-10 flex flex-col md:flex-row items-center justify-between p-10 md:p-16 gap-10">
            <div class="max-w-xl">
                <h2 class="text-3xl md:text-5xl font-black mb-4 tracking-tight">
                    @Model.Title
                </h2>

                <p class="text-gray-300 text-lg mb-8">
                    @Model.Subtitle
                </p>

                <a href="@(string.IsNullOrWhiteSpace(Model.LinkUrl) ? "/Product" : Model.LinkUrl)"
                   class="flex items-center justify-center rounded-full h-12 px-8 bg-primary text-[#181811] text-base font-bold hover:brightness-110 transition-all w-fit">
                    Khám Phá Ngay
                </a>
            </div>

            <div class="w-full md:w-1/2 flex justify-center">
                <img class="rounded-xl shadow-2xl rotate-3 hover:rotate-0 transition-transform duration-500 max-w-full md:max-w-md border-4 border-white/10"
                     src="@Model.ImageUrl" alt="@Model.Title" />
            </div>
        </div>
    </div>
</section>


