<section class="w-full max-w-[1440px] px-6 md:px-10 py-6 mx-auto">
    <h2 class="text-[#181811] text-[22px] font-bold leading-tight tracking-[-0.015em] pb-6">Danh mục phổ biến</h2>
    <div class="flex gap-4 flex-wrap pb-2">

        @foreach (var item in Model)
        {
            <a href="/Product?type=@item.LinkType&value=@item.LinkValue" 
            class="group flex h-12 items-center gap-3 rounded-full bg-white border border-gray-100 pl-4 pr-6 hover:border-primary hover:shadow-md transition-all">
                <div class="flex size-8 items-center justify-center rounded-full bg-neutral-light group-hover:bg-primary transition-colors">
                    <span class="material-symbols-outlined text-[20px]">@item.Icon</span>
                </div>
                <span class="text-[#181811] font-bold">@item.Name</span>
            </a>  
            

            @* <a href="/Product?type=@item.LinkType&value=@item.LinkValue"
