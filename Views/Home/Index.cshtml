</section>

<section class="w-full max-w-[1440px] px-6 md:px-10 py-8 mb-12 mx-auto">
    <div class="relative w-full rounded-[2.5rem] overflow-hidden bg-[#1a1a1a] text-white">
        <div class="absolute inset-0 bg-cover bg-center opacity-40 mix-blend-overlay" style="background-image: url('https://placehold.co/1200x600?text=Gaming+Abstract');"></div>
        <div class="relative z-10 flex flex-col md:flex-row items-center justify-between p-10 md:p-16 gap-10">
            <div class="max-w-xl">
                <h2 class="text-3xl md:text-5xl font-black mb-4 tracking-tight">Chiến Game Đỉnh Cao<br /><span class="text-primary">Không Giới Hạn</span></h2>
                <p class="text-gray-300 text-lg mb-8">Trải nghiệm sức mạnh đồ họa RTX 40 Series mới nhất trên các dòng Laptop Gaming cao cấp.</p>
                <button class="flex items-center justify-center rounded-full h-12 px-8 bg-primary text-[#181811] text-base font-bold hover:brightness-110 transition-all">
                    Khám Phá Ngay
                </button>
            </div>
            <div class="w-full md:w-1/2 flex justify-center">
                <img class="rounded-xl shadow-2xl rotate-3 hover:rotate-0 transition-transform duration-500 max-w-full md:max-w-md border-4 border-white/10"
                     src="https://placehold.co/500x350?text=Gaming+Laptop" />
            </div>
        </div>
    </div>
</section>

<section class="w-full max-w-[1440px] px-6 md:px-10 py-12 mb-8 bg-white border-t border-gray-100 mx-auto">
    <div class="flex flex-col md:flex-row items-center justify-between gap-8 max-w-5xl mx-auto">
        <div class="flex flex-col gap-2 text-center md:text-left">
            <h3 class="text-2xl font-bold">Đăng ký nhận tin</h3>
            <p class="text-gray-500">Nhận thông tin khuyến mãi và mã giảm giá sớm nhất.</p>
        </div>
        <div class="flex w-full max-w-md gap-2">
            <input class="flex-1 rounded-full border border-gray-200 bg-neutral-light px-6 py-3 text-base outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-all" placeholder="Email của bạn" type="email" />
            <button class="rounded-full bg-primary px-8 py-3 font-bold text-[#181811] hover:brightness-95 transition-all whitespace-nowrap">Đăng ký</button>
        </div>
    </div>
</section>