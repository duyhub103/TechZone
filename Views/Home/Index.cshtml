@{
    ViewData["Title"] = "Trang chủ";
}

<section class="w-full max-w-[1440px] px-6 md:px-10 py-8 mx-auto">
    <div class="relative overflow-hidden rounded-[2.5rem] bg-[#f2f2eb]">
        <div class="flex flex-col lg:flex-row items-center gap-8 p-8 md:p-12 lg:p-16">
            <div class="flex flex-col gap-6 lg:w-1/2 z-10">
                <div class="flex flex-col gap-2">
                    <span class="inline-block w-fit px-3 py-1 rounded-full bg-primary text-xs font-bold uppercase tracking-wider">Khuyến mãi hè</span>
                    <h1 class="text-[#181811] text-4xl md:text-5xl lg:text-6xl font-black leading-[1.1] tracking-[-0.02em]">
                        MacBook Air M2<br />Siêu Mỏng, Siêu Mạnh
                    </h1>
                    <p class="text-[#5c5b4f] text-lg font-medium leading-normal max-w-md mt-2">
                        Giảm ngay 15% cho các dòng sản phẩm Apple M2. Tặng kèm chuột Magic Mouse khi mua online.
                    </p>
                </div>
                <div class="flex gap-4 mt-2">
                    <button class="flex items-center justify-center rounded-full h-12 px-8 bg-primary text-[#181811] text-base font-bold hover:brightness-95 transition-all shadow-lg shadow-primary/20">
                        Mua Ngay
                    </button>
                    <button class="flex items-center justify-center rounded-full h-12 px-8 bg-white border border-gray-200 text-[#181811] text-base font-bold hover:bg-gray-50 transition-all">
                        Xem Chi Tiết
                    </button>
                </div>
            </div>
            <div class="lg:w-1/2 flex justify-center lg:justify-end relative">
                <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[120%] h-[120%] bg-gradient-to-tr from-primary/30 to-transparent rounded-full blur-3xl -z-10"></div>
                <div class="w-full max-w-[500px] aspect-[4/3] bg-contain bg-center bg-no-repeat transition-transform hover:scale-105 duration-500"
                     style="background-image: url('https://placehold.co/600x450?text=Macbook+Air+M2'); border-radius: 2rem;">
                </div>
            </div>
        </div>
    </div>
</section>

