
@using MyWeb.Models
@using MyWeb.ViewModels
@model HomeViewModel

@{
    ViewData["Title"] = "Trang chủ";
}

<partial name="Partials/_HeroSection" model="Model.MainSliders" />

<partial name="Partials/_CategorySection" model="Model.PopularCategories"/>

<partial name="Partials/_HomeProductList"
         model="@(new HomeProductListSectionViewModel { Title = "Sản phẩm nổi bật", Products = Model.FeaturedProducts })" />

<partial name="Partials/_HomeProductList"
         model="@(new HomeProductListSectionViewModel { Title = "Sản phẩm mới nhất", Products = Model.LatestProducts })" />

<partial name="Partials/_HomeProductList"
         model="@(new HomeProductListSectionViewModel { Title = "Sản phẩm bán chạy", Products = Model.BestSellingProducts })" />


@if (Model.PromoBanner != null)
{
    <partial name="Partials/_PromoSection" model="Model.PromoBanner" />
}
<partial name="_NewsletterSection" />







