                <div class="absolute top-3 left-3 bg-red-500 text-white text-xs font-bold px-2 py-1 rounded-full z-10">-5%</div>
                <div class="w-full h-full bg-center bg-cover transition-transform duration-500 group-hover:scale-110"
                     style="background-image: url('https://placehold.co/400x400?text=ThinkPad+X1');"></div>
                <button class="absolute bottom-3 right-3 size-10 bg-white rounded-full flex items-center justify-center shadow-md opacity-0 translate-y-2 group-hover:opacity-100 group-hover:translate-y-0 transition-all duration-300 hover:bg-primary">
                    <span class="material-symbols-outlined text-[20px]">add_shopping_cart</span>
